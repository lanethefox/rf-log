{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RF-LOG",
  "version": "0.1.0",
  "identifier": "com.rflog.app",
  "build": {
    "frontendDist": "../ui/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm --prefix ../ui run dev",
    "beforeBuildCommand": "npm --prefix ../ui run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "RF-LOG",
        "width": 1320,
        "height": 860,
        "minWidth": 1000,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
